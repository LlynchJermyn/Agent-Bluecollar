# API Einstellungen
API_HOST=0.0.0.0
API_PORT=8001

# OpenAI API Key
OPENAI_ENDPOINT=https://api.openai.com/v1
OPENAI_API_KEY=

#Azure OPENAI API Key
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_MODEL=
AZURE_OPENAI_API_VERSION=

# LLM
LLM_MODEL=gpt-5-nano
LLM_TEMPERATURE=0.1  

# Browser Einstellungen (true für Docker, false für lokales Testen mit UI)
HEADLESS=true

#Maximale Schritte pro Adresse (Iteration Limit)
MAX_STEPS=8