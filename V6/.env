# Agent Steuerung
HEADLESS=true
API_PORT=8001

# Akamai & Bot-Schutz
GLOBAL_STAGGER_SECONDS=10.0
TYPING_DELAY_MS=40
HOVER_DELAY_MS=400

# Timeouts & Polling
PAGE_TIMEOUT_MS=40000
POLLING_TIMEOUT_MS=40000
POLLING_INTERVAL_MS=500

# System (Interner Pfad im Container)
SHARED_LOCK_FILE=/shared/stagger.lock